PORT=3001

# Database connection (MySQL)
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_PORT=3306

# Prisma DATABASE_URL (MySQL)
DATABASE_URL="mysql://your_db_user:your_db_password@127.0.0.1:3306/your_db_name"

# Session and CORS
SESSION_SECRET=replace-with-a-random-secret
ACCESS_TOKEN_SECRET=replace-with-a-random-access-token-secret
REFRESH_TOKEN_SECRET=replace-with-a-random-refresh-token-secret
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800
ACCESS_TOKEN_TTL_SEC_REMEMBER=604800
REFRESH_TOKEN_TTL_SEC_REMEMBER=2592000
CORS_ORIGIN=http://localhost:3000
FRONTEND_AFTER_LOGIN_URL=http://localhost:3000/member/dashboard
SUPPORT_EMAILS=support@example.com

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="PetFull <no-reply@example.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/oauth/google/callback

# ========================================
# AI Chat
# ========================================
AI_ENABLED=true
AI_PROVIDER=gemini
AI_TIMEOUT_MS=10000
AI_MAX_TOKENS=300
AI_TEMPERATURE=0.4
AI_MODEL=gemini-3.5-flash

# ========================================
# Google Gemini (AI Studio)
# ========================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ========================================
# OpenAI Compatible (Optional fallback provider)
# ========================================
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=

NODE_ENV=development